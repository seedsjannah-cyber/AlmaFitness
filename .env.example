# Environment Variables Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control

# ===================================
# Stripe Payment Gateway
# ===================================
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ===================================
# PayPal Payment Gateway
# ===================================
PAYPAL_CLIENT_ID=your_paypal_client_id_here
PAYPAL_CLIENT_SECRET=your_paypal_client_secret_here
PAYPAL_MODE=sandbox  # or 'live' for production

# ===================================
# Email Service (SendGrid)
# ===================================
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here
FROM_EMAIL=hello@almasfitness.com
FROM_NAME=Alma's Fitness

# ===================================
# Email Service (Mailgun) - Alternative
# ===================================
# MAILGUN_API_KEY=your_mailgun_api_key_here
# MAILGUN_DOMAIN=mg.almasfitness.com

# ===================================
# Email Service (SMTP) - Alternative
# ===================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_app_specific_password

# ===================================
# CMS (Sanity)
# ===================================
SANITY_PROJECT_ID=your_sanity_project_id
SANITY_DATASET=production
SANITY_TOKEN=your_sanity_token  # Optional, for authenticated requests

# ===================================
# CMS (Strapi) - Alternative
# ===================================
# STRAPI_URL=http://localhost:1337
# STRAPI_API_TOKEN=your_strapi_api_token

# ===================================
# Database (if using backend)
# ===================================
# DATABASE_URL=mongodb://localhost:27017/almas-fitness
# or
# DATABASE_URL=postgresql://user:password@localhost:5432/almas_fitness

# ===================================
# Application Settings
# ===================================
NODE_ENV=development  # or 'production'
PORT=3000
BASE_URL=http://localhost:3000  # Change to your domain in production

# ===================================
# Google Services
# ===================================
GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ===================================
# AWS (if using for storage/email)
# ===================================
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=almas-fitness-uploads

# ===================================
# Social Media URLs
# ===================================
INSTAGRAM_URL=https://instagram.com/yourhandle
FACEBOOK_URL=https://facebook.com/yourpage
YOUTUBE_URL=https://youtube.com/yourchannel
LINKEDIN_URL=https://linkedin.com/in/yourprofile

# ===================================
# Security
# ===================================
JWT_SECRET=your_very_secure_random_string_here
SESSION_SECRET=another_very_secure_random_string_here

# ===================================
# Third-party Integrations
# ===================================
# CALENDLY_API_KEY=your_calendly_api_key  # For calendar integration
# ZOOM_API_KEY=your_zoom_api_key  # For video sessions
# ZOOM_API_SECRET=your_zoom_api_secret

# ===================================
# Analytics & Monitoring
# ===================================
# SENTRY_DSN=https://your_sentry_dsn  # Error tracking
# MIXPANEL_TOKEN=your_mixpanel_token  # Analytics
